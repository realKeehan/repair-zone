# ─────────────────────────────────────────────────────────────
#  The Repair Zone — environment configuration
#  Copy this file to `.env` and fill in the values.
# ─────────────────────────────────────────────────────────────

# Web server
PORT=3000
# Public base URL of the site (used in Discord links back to the admin panel)
PUBLIC_BASE_URL=http://localhost:3000

# Admin panel token — required to view/manage the queue & inventory.
# Use a long random string. Generate one with:  node -e "console.log(crypto.randomUUID())"
ADMIN_TOKEN=change-me-to-a-long-random-string

# ─────────────────────────────────────────────────────────────
#  Discord bot (optional — the website works without it)
# ─────────────────────────────────────────────────────────────

# Bot token from https://discord.com/developers/applications  ->  Bot
DISCORD_BOT_TOKEN=

# Application (client) ID  ->  General Information
DISCORD_CLIENT_ID=

# The server (guild) ID where slash commands are registered.
# Right-click your server icon -> Copy Server ID (Developer Mode must be on).
DISCORD_GUILD_ID=

# The FORUM channel where new repair requests are posted as forum threads.
# Right-click the forum channel -> Copy Channel ID.
DISCORD_FORUM_CHANNEL_ID=

# Optional: a normal text channel that receives a log line for every
# new repair request and tool checkout (staff notifications).
# Leave blank to disable. You can use a channel ID or a full webhook URL below.
DISCORD_LOG_CHANNEL_ID=

# Optional webhook URL (alternative to a log channel; used if set).
DISCORD_WEBHOOK_URL=
