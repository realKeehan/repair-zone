# ─────────────────────────────────────────────────────────────
#  The Repair Zone — environment configuration
#  Copy this file to `.env` and fill in the values.
# ─────────────────────────────────────────────────────────────

# Web server
PORT=3000
# Public base URL of the site (used in Discord links back to the admin panel)
PUBLIC_BASE_URL=http://localhost:3000

# Reverse-proxy hops to trust for the real client IP (X-Forwarded-For).
# Behind Cloudflare + cPanel/Passenger, 1 is the usual value. Local dev: 1 is fine.
TRUST_PROXY=1

# How the admin panels (/admin, /api/admin) are protected. Two options:
#
#  A) App token (default). Set ADMIN_TOKEN to a long random string; staff log in
#     with it. Generate one:  node -e "console.log(crypto.randomUUID())"
#  B) Apache Basic Auth via .htaccess (cPanel/Namecheap). Set ADMIN_AUTH=external
#     and protect /admin + /api/admin in .htaccess (see .htaccess.example). The
#     app then trusts Apache and ignores ADMIN_TOKEN.
#
# Leave ADMIN_AUTH blank for option A. Use "external" for option B.
#
# There is no default: if ADMIN_TOKEN is left unset (and ADMIN_AUTH is not
# "external"), the admin API fails closed (503) rather than accepting a
# guessable password. Set a long random value — that string IS your admin login.
ADMIN_AUTH=
ADMIN_TOKEN=change-me-to-a-long-random-string

# ─────────────────────────────────────────────────────────────
#  Discord bot (optional — the website works without it)
# ─────────────────────────────────────────────────────────────

# Bot token from https://discord.com/developers/applications  ->  Bot
DISCORD_BOT_TOKEN=

# Application (client) ID  ->  General Information
DISCORD_CLIENT_ID=

# The server (guild) ID where slash commands are registered.
# Right-click your server icon -> Copy Server ID (Developer Mode must be on).
DISCORD_GUILD_ID=

# The FORUM channel where new repair requests are posted as forum threads.
# Right-click the forum channel -> Copy Channel ID.
DISCORD_FORUM_CHANNEL_ID=

# Optional: a normal text channel that receives a log line for every
# new repair request and tool checkout (staff notifications).
# Leave blank to disable. You can use a channel ID or a full webhook URL below.
DISCORD_LOG_CHANNEL_ID=

# Optional webhook URL (alternative to a log channel; used if set).
DISCORD_WEBHOOK_URL=

# ─────────────────────────────────────────────────────────────
#  Online waiver (optional — /waiver page)
# ─────────────────────────────────────────────────────────────

# The /waiver page embeds a Tally form (https://tally.so) so people can read
# and sign the liability waiver online. Tally's free plan supports signature
# fields and high submission volume. Create a form, then paste its ID here —
# it's the code in the share URL, e.g. tally.so/r/wA1bCd  ->  wA1bCd.
# (A full tally.so URL works too.) Leave blank to show a "not set up yet"
# message instead of a broken embed. See docs/WAIVER-SETUP.md.
TALLY_WAIVER_FORM_ID=
